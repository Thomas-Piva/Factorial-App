    "db:reset": "supabase db reset && node scripts/seed-auth.mjs"
  },
  "dependencies": {
    "@serwist/next": "^9.0.14",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "2.49.4",
